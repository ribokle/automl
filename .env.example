ANTHROPIC_API_KEY=sk-ant-...
RUN_DIR=./runs
DB_URL=sqlite+aiosqlite:///./automl.db
LLM_DRY_RUN=true

# API server (FastAPI)
# Comma-separated origins allowed by CORS; falls back to localhost:3000 if unset.
ALLOWED_ORIGINS=http://localhost:3000
# If set, every API route (except /health) requires `Authorization: Bearer <token>`.
# Leave empty to disable auth (dev default).
API_AUTH_TOKEN=
# Hard cap on upload size in MiB (default 200).
MAX_UPLOAD_MB=200

# Next.js (web/)
# Where the Next.js route handler at /api/[...path] forwards to.
API_PROXY_TARGET=http://localhost:8000
# Same token the API enforces; the Next.js proxy injects it as Authorization.
# Never prefixed with NEXT_PUBLIC_ — must stay server-side so the client bundle
# doesn't carry the secret.
# API_AUTH_TOKEN=
NEXT_PUBLIC_API_BASE=http://localhost:8000
